{
  "name": "mp-search-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Conversational job-search POC \u2014 Elasticsearch + local LLM (Ollama), single node on bowmore",
  "workspaces": [
    "packages/shared",
    "packages/ingest",
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "setup": "tsx packages/ingest/src/setup-index.ts",
    "setup:endpoint": "tsx packages/ingest/src/setup-endpoint.ts",
    "ingest": "tsx packages/ingest/src/ingest.ts",
    "geocode": "tsx packages/ingest/src/geocode.ts",
    "dev:api": "tsx watch packages/api/src/server.ts",
    "dev:web": "npm --workspace @search/web run dev",
    "dev": "concurrently -k -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "es:up": "docker compose -f deploy/bowmore-single/docker-compose.yml up -d",
    "es:down": "docker compose -f deploy/bowmore-single/docker-compose.yml down",
    "es:logs": "docker compose -f deploy/bowmore-single/docker-compose.yml logs -f --tail=100",
    "eval": "tsx packages/api/src/eval.ts"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
