# ---- Elasticsearch (runs on kilchoman) ----
ES_URL=http://192.168.68.56:9200
ES_INDEX=jobs
# Security is disabled on the POC cluster (LAN-only), so no creds needed.
# If you enable security later, set these:
# ES_USERNAME=elastic
# ES_PASSWORD=changeme

# ---- LLM (Ollama on bowmore, OpenAI-compatible) ----
# Swap LLM_BASE_URL/LLM_MODEL/LLM_API_KEY to point at Azure OpenAI or Vertex for the prod assessment.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=ollama

# ---- Embeddings (Ollama native API on bowmore) ----
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=nomic-embed-text
EMBED_DIMS=768

# ---- Retrieval ----
# bm25 | dense | elser   (the web UI can override per-request)
SEMANTIC_MODE=dense

# ---- Data ----
FEED_URL=https://www.michaelpage.co.uk/sites/michaelpage.co.uk/files/reports/job_advert_xml/SA-360-jobs.xml

# ---- API ----
API_PORT=3001
WEB_ORIGIN=http://localhost:5173
